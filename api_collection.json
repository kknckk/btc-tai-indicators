            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "metrics",
            "available"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Metrics Values",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/metrics/values?metrics=PriceUSD&metrics=MVRV_Z&start_date=2012-01-01&end_date=2026-12-31",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "metrics",
            "values"
          ],
          "query": [
            {
              "key": "metrics",
              "value": "PriceUSD"
            },
            {
              "key": "metrics",
              "value": "MVRV_Z"
            },
            {
              "key": "start_date",
              "value": "2012-01-01"
            },
            {
              "key": "end_date",
              "value": "2026-12-31"
            }
          ]
        }
      },
      "response": []
